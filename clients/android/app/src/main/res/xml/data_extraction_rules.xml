<?xml version="1.0" encoding="utf-8"?><!--
   Backup / transfer is disabled at the application level (android:allowBackup="false").
   These rules are defense-in-depth: if backup is ever re-enabled, the local task
   database (which is not encrypted at rest) must never leave the device.
   See plan-To-Do-App.md: "Exclude vault databases, plaintext exports, and
   secret-bearing diagnostics from automatic backup."
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" path="eisenhower_tasks.db" />
        <exclude domain="database" path="eisenhower_tasks.db-wal" />
        <exclude domain="database" path="eisenhower_tasks.db-shm" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="database" path="eisenhower_tasks.db" />
        <exclude domain="database" path="eisenhower_tasks.db-wal" />
        <exclude domain="database" path="eisenhower_tasks.db-shm" />
    </device-transfer>
</data-extraction-rules>
