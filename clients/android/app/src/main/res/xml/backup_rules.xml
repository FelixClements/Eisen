<?xml version="1.0" encoding="utf-8"?><!--
   Legacy auto-backup rules (devices below API 31). Backup is disabled at the
   application level (android:allowBackup="false"); these exclusions are
   defense-in-depth so the unencrypted local task database is never backed up
   if backup is ever re-enabled.
-->
<full-backup-content>
    <exclude domain="database" path="eisenhower_tasks.db" />
    <exclude domain="database" path="eisenhower_tasks.db-wal" />
    <exclude domain="database" path="eisenhower_tasks.db-shm" />
</full-backup-content>
